# RingCentral API Credentials
# Obtain from: https://developers.ringcentral.com > Console > Applications
RC_CLIENT_ID=your_client_id_here
RC_CLIENT_SECRET=your_client_secret_here

# JWT Authentication (preferred for server-to-server)
# Generate at: https://developers.ringcentral.com > Console > Credentials
RC_JWT_TOKEN=your_jwt_token_here

# RingCentral Server URL
# Production: https://platform.ringcentral.com
# Sandbox:    https://platform.devtest.ringcentral.com
RC_SERVER_URL=https://platform.ringcentral.com

# Golden Number (E.164 format)
RC_GOLDEN_NUMBER=+17608888888

# Fax extension number
RC_FAX_EXTENSION=500

# Webhook Configuration
WEBHOOK_BASE_URL=https://your-server.unicareathome.com
WEBHOOK_VERIFICATION_TOKEN=your_random_secret_token_here

# Flask Configuration
FLASK_SECRET_KEY=generate_a_random_secret_key_here
FLASK_ENV=production

# Audit Log Configuration
AUDIT_LOG_DIR=/var/log/unicare/ucaas
AUDIT_LOG_RETENTION_DAYS=365

# HIPAA: Never put PHI in environment variables.
# These credentials should be stored in a secrets manager
# (e.g., AWS Secrets Manager, HashiCorp Vault) in production.
